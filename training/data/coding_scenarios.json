{
  "description": "Coding scenarios for HSM-II training",
  "version": "1.0",
  
  "tasks": [
    {
      "id": "code_review_001",
      "type": "code_review",
      "description": "Review a Rust function for memory safety issues",
      "input": {
        "code": "fn process_data(data: &mut Vec<u32>) {\n    for i in 0..data.len() {\n        data[i] = data[i].wrapping_add(1);\n    }\n}",
        "language": "rust"
      },
      "expected_outcomes": ["identify_potential_overflow", "suggest_iter_mut"],
      "complexity": 0.4,
      "urgency": 0.6
    },
    {
      "id": "refactor_001", 
      "type": "refactoring",
      "description": "Refactor nested match statements into flat structure",
      "input": {
        "code": "match result {\n    Ok(val) => match val {\n        Some(v) => process(v),\n        None => handle_empty(),\n    },\n    Err(e) => handle_error(e),\n}",
        "language": "rust"
      },
      "expected_outcomes": ["use_and_then", "flatten_structure"],
      "complexity": 0.6,
      "urgency": 0.4
    },
    {
      "id": "architecture_001",
      "type": "architecture",
      "description": "Design a hypergraph data structure for concurrent access",
      "input": {
        "requirements": [
          "Support concurrent reads",
          "Support concurrent writes to different edges",
          "Maintain coherence metric on each mutation"
        ]
      },
      "expected_outcomes": ["use_rwlock", "arc_for_shared_state", "coherence_cache"],
      "complexity": 0.85,
      "urgency": 0.3
    },
    {
      "id": "debug_001",
      "type": "debugging",
      "description": "Find the deadlock in a multi-agent message passing system",
      "input": {
        "symptoms": [
          "System hangs after ~1000 ticks",
          "All agents waiting on locks",
          "Message queue growing unbounded"
        ]
      },
      "expected_outcomes": ["identify_circular_wait", "suggest_timeout", "recommend_channel_buffering"],
      "complexity": 0.75,
      "urgency": 0.9
    },
    {
      "id": "optimize_001",
      "type": "optimization",
      "description": "Optimize council decision caching for LLM calls",
      "input": {
        "current": "HashMap<String, Decision>",
        "problem": "Memory usage growing unbounded with 10k+ proposals",
        "constraints": ["Sub-10ms lookup", "Thread-safe"]
      },
      "expected_outcomes": ["implement_lru", "add_ttl", "use_arc_mutex"],
      "complexity": 0.7,
      "urgency": 0.7
    },
    {
      "id": "testing_001",
      "type": "testing",
      "description": "Write property-based tests for hypergraph mutations",
      "input": {
        "properties": [
          "Coherence should never decrease on valid mutation",
          "Edge count should equal sum of all agent contributions",
          "Ontology should remain consistent after any sequence of operations"
        ]
      },
      "expected_outcomes": ["use_proptest", "define_invariants", "generate_arbitrary_graphs"],
      "complexity": 0.8,
      "urgency": 0.5
    },
    {
      "id": "api_design_001",
      "type": "api_design",
      "description": "Design async API for batch experiment runner",
      "input": {
        "requirements": [
          "Support 1000+ parallel runs",
          "Progress reporting per run",
          "Graceful degradation on LLM timeout"
        ]
      },
      "expected_outcomes": ["use_tokio_joinset", "implement_cancellation", "add_backpressure"],
      "complexity": 0.65,
      "urgency": 0.6
    },
    {
      "id": "documentation_001",
      "type": "documentation",
      "description": "Document the DKS (Dynamic Knowledge System) module",
      "input": {
        "module": "dks",
        "components": ["population", "selection", "replicator", "stigmergic_entity"],
        "audience": "New contributors with ML background"
      },
      "expected_outcomes": ["explain_ecological_metaphor", "document_trait_bounds", "add_examples"],
      "complexity": 0.5,
      "urgency": 0.4
    }
  ],
  
  "difficulty_distribution": {
    "easy": 0.25,
    "medium": 0.5,
    "hard": 0.25
  },
  
  "success_criteria": {
    "coherence_threshold": 0.7,
    "skill_promotion_rate": 0.75,
    "council_approval_rate": 0.6,
    "mean_resolution_time_ticks": 50
  }
}
