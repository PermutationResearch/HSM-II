# HSM-II Environment Configuration
# Copy to .env and fill in your values

# =============================================================================
# LLM Configuration (at least one required)
# =============================================================================

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1  # Optional

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1  # Optional

# Ollama (local inference, no API key needed)
OLLAMA_URL=http://localhost:11434

# OpenRouter (OpenAI-compatible, optional)
OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_API_BASE=https://openrouter.ai/api/v1  # optional
# DEFAULT_LLM_MODEL=openai/gpt-oss-120b:free  # example live free OpenRouter model
# HSM_LLM_PROVIDER_ORDER=openrouter,openai,xai,anthropic,ollama

# Default model to use
DEFAULT_LLM_MODEL=openai/gpt-oss-120b:free
# Company console: operator chat + POST /api/skill-run (overrides DEFAULT_LLM_MODEL when set)
# HSM_AGENT_CHAT_MODEL=openai/gpt-oss-120b:free
# Secret for POST /api/skill-run (Bearer or JSON body); required for cron / external automation
# HSM_SKILL_RUN_SECRET=

# Business pack persona for integrated/enhanced personal agent (optional)
# Requires `business/pack.yaml` under HSMII_HOME — see documentation/guides/BUSINESS_PACK.md
# Validate: cargo run -p hyper-stigmergy --bin hsm-business-pack -- validate --home ~/.hsmii
# HSM_BUSINESS_PERSONA=administration
#
# Québec copropriété / syndic-style manager role (déclaration, règlements, procédures; tenant vs syndic vs co-owner bailleur)
# HSM_COOWNER_MANAGER_ROLE=1
# Optional: merge templates/hsmii/AGENTS.coowner_manager.example.md into <HSMII_HOME>/AGENTS.md and use business/pack.yaml (e.g. gestion_velora starter) for governing docs.
#
# Enterprise ops YAML for tools `read_operations` / `list_tickets` (default: <HSMII_HOME>/config/operations.yaml)
# Copy templates/hsmii/operations.example.yaml → config/operations.yaml
# HSM_OPERATIONS_YAML=/path/to/operations.yaml
#
# Company OS (hsm_console): PostgreSQL for companies / goals / tasks / budgets schema
#
# Easiest local DB (Docker): from repo root run  ./scripts/company_os_postgres.sh up
# then copy the line below into your real `.env` and restart hsm_console.
# HSM_COMPANY_OS_DATABASE_URL=postgres://hsm:hsm@127.0.0.1:55432/hsm_company_os
#
# Without Docker (Homebrew Postgres on default port 5432):
#   brew install postgresql@16 && brew services start postgresql@16
#   ./scripts/company_os_postgres_local.sh
# HSM_COMPANY_OS_DATABASE_URL=postgres://hsm:hsm@127.0.0.1:5432/hsm_company_os
#
# Manual example: docker run -d --name hsm-pg -e POSTGRES_PASSWORD=dev -e POSTGRES_USER=hsm -e POSTGRES_DB=hsm -p 5433:5432 postgres:16
# HSM_COMPANY_OS_DATABASE_URL=postgres://hsm:dev@127.0.0.1:5433/hsm
#
# Company API base for tool `company_task_requires_human` (default matches hsm_console :3847).
# HSM_COMPANY_API_BASE=http://127.0.0.1:3847
#
# personal_agent start: serve the same /api/company + /api/console stack as `hsm_console` in-process
# (shared Paperclip IntelligenceLayer + optional Postgres). Set 0 if you run `hsm_console` separately.
# HSM_EMBED_CONSOLE_API=1
# HSM_CONSOLE_PORT=3847
# HSM_API_PORT=3000
# Optional: active task UUID when agents omit task_id in that tool
# HSM_COMPANY_TASK_ID=
# Optional: company / workforce agent UUID for tools `company_memory_search` / `company_memory_append` (else resolved via task llm-context)
# HSM_COMPANY_ID=
# HSM_COMPANY_AGENT_ID=
# Company shared/agent memory blocks in GET …/tasks/:id/llm-context: newest rows only + UTF-8 cap (defaults: 1 row, 3072 bytes)
# HSM_COMPANY_MEMORY_LLM_CONTEXT_ENTRY_LIMIT=1
# HSM_COMPANY_MEMORY_LLM_CONTEXT_MAX_BYTES=3072
# HSM_VISION_ALIGNMENT_LLM_ADDON=1            # inject YC-Bench strategy snapshot into GET /api/company/tasks/{id}/llm-context (set 0 to disable)
# Optional Bearer for secured company API proxies
# HSM_COMPANY_API_BEARER=
# Enterprise route-level bearer auth for Company OS API
# HSM_COMPANY_API_BEARER_TOKEN=replace-with-strong-random-token
# Dev-only bypass for Company OS auth middleware when bearer is unset
# HSM_COMPANY_API_ALLOW_NO_AUTH=0
# Optional DB pool tuning for Company OS
# HSM_COMPANY_OS_DB_MAX_CONNECTIONS=20
# Credential encryption key (32 bytes; raw or base64:... format)
# HSM_COMPANY_CREDENTIALS_KEY=base64:REPLACE_WITH_32_BYTE_KEY_BASE64
# Enforce fail-closed when credential key is not configured
# HSM_COMPANY_REQUIRE_CREDENTIAL_ENCRYPTION=1
# Optional explicit company for heartbeat sync (avoids first-company heuristic)
# HSM_PRIMARY_COMPANY_ID=
# Generic API auth gate (disabled by default; applies to /api/* except /api/health)
# HSM_API_REQUIRE_AUTH=0
# HSM_API_BEARER_TOKEN=replace-with-strong-random-token
# Browser UI/API origins for local CORS
# HSM_API_ALLOWED_ORIGINS=http://127.0.0.1:3001,http://localhost:3001
# HSM_CONSOLE_ALLOWED_ORIGINS=http://127.0.0.1:3001,http://localhost:3001
#
# Enhanced / integrated agent — phased ops (optional)
# HSM_HEARTBEAT_INTERVAL_SECS=3600          # run HEARTBEAT.md tick at most once per hour while handling messages
# HSM_MEMORY_JOURNAL=1                        # append each turn to memory/journal/YYYY-MM-DD.md
# HSM_OUTBOUND_WEBHOOK_URL=https://...      # POST JSON {source,user_preview,assistant_preview} after each turn (Zapier/Make/Monday inbound)
# HSM_EMAIL_DRAFT_SIMPLE=1                  # `/email answer`: one LLM call only (skip read_eml / Maildir / read_file tool loop)

# Firecrawl — tool `firecrawl_scrape` (see src/tools/firecrawl_tool.rs)
#
# Self-hosted OSS (Docker/VPS): point at your API; `/v1` is added if omitted. Key often unnecessary.
# FIRECRAWL_API_URL=http://localhost:3002
# FIRECRAWL_API_KEY=...                         # only if your instance enforces auth
#
# Official cloud: key required.
# FIRECRAWL_API_KEY=fc-...
# FIRECRAWL_API_BASE=https://api.firecrawl.dev/v1   # optional; this is the default when URL unset

# Browser Use provider bridge (`browser_use_run`)
# BROWSER_USE_API_KEY=...
# BROWSER_USE_API_BASE=https://api.browser-use.com/v1
#
# After successful web_search / browser_get_text / firecrawl_scrape, push extractive summary into world (enhanced agent or IntegratedToolExecutor + world)
# HSM_WEB_INGEST=1                           # record_experience + memory::derive_hierarchy summary
# HSM_WEB_INGEST_BELIEFS=1                  # also add_belief_with_extras (Observation, modest confidence + supporting_evidence)
# HSM_WEB_INGEST_MAX_CHARS=8000             # cap stored body
# HSM_WEB_INGEST_BELIEF_MIN_CHARS=80        # min body length before creating a belief
#
# Tool firewall + audit trail (personal / enhanced agent)
# HSM_TOOL_ALLOW=read_file,read_eml,grep      # if set: only these exact tool names may execute
# HSM_TOOL_BLOCK_PREFIXES=bash,git_,write   # deny tools whose name starts with any prefix
# HSM_TASK_TRAIL=0                           # disable append-only JSONL at <home>/memory/task_trail.jsonl (default on)
#
# Bash safety (Claude layer 6): quote-aware strict preflight — no pipes, redirects, $(…), `…`, &&, ||, ;, background &.
# HSM_BASH_POLICY=strict
#
# Host bash network isolation (layer 7, local bash only — not Docker): requires external tools / OS.
# HSM_BASH_ISOLATE=firejail   # firejail --net=none --quiet --
# HSM_BASH_ISOLATE=unshare    # Linux: unshare -n -- (may need capabilities)
#
# Docker bash: container egress (default is NO egress — `--network none`).
# Use `bridge`, `host`, etc. for outbound network from the container; `default` = omit --network (daemon default).
# HSM_DOCKER_BASH_NETWORK=bridge
#
# Unified LLM HTTP policy (layers 2–3): per-provider retries before failover + reqwest timeout.
# HSM_LLM_MAX_RETRIES=3
# HSM_LLM_RETRY_BASE_MS=1000
# HSM_LLM_RETRY_MAX_MS=30000
# HSM_LLM_RETRY_EXP_BASE=2
# HSM_LLM_HTTP_TIMEOUT_SECS=120
# Long request timeout for streaming chat bodies (default 600).
# HSM_LLM_STREAM_TIMEOUT_SECS=600
#
# Ollama-only streaming: put ollama first and use an installed model name.
# HSM_LLM_PROVIDER_ORDER=ollama
# DEFAULT_LLM_MODEL=llama3.2
# Note: LlmClient::chat rejects stream:true until a streaming consumer exists.

# Prompt router + memory pipeline (personal / enhanced agent)
# Copy templates/hsmii/prompt_routes.example.yaml → <HSMII_HOME>/config/prompt_routes.yaml
# HSM_MEMORY_PREFETCH=1                      # scan memory/*.md + one LLM call to pick N files for context
# HSM_MEMORY_PREFETCH_N=1                    # default 1 file; raise if you want broader recall
# HSM_MEMORY_PREFETCH_PER_FILE_MAX_BYTES=2048
# HSM_MEMORY_PREFETCH_TOTAL_MAX_BYTES=4096
# HSM_MEMORY_PREFETCH_INCLUDE_EXTRACTS=1   # include memory/extracts/*.md in prefetch manifest
# HSM_MEMORY_EXTRACT=1                       # post-turn: forked summarize → memory/extracts/*.md
# HSM_MEMORY_EXTRACT_MODEL=llama3.2        # optional smaller/cheaper model for extract
#
# Hermes-style instruction files (under HSMII_HOME): AGENTS.md is injected before a small MEMORY.md excerpt + USER.md
# HSM_MEMORY_MD_MAX_BYTES=2560               # MEMORY.md cap (AGENTS.md: HSM_AGENTS_MD_MAX_BYTES, default 24KiB)
# HSM_AGENTS_MD_MAX_BYTES=24576
# HSM_INSTR_HOT_RELOAD=1                   # reload those excerpts from disk on each handled message
#
# Personal agent MCP (same plugin manifests as coder assistant): HTTP JSON-RPC tools/call + optional tools/list
# HSM_PERSONAL_MCP_DISCOVER=1              # merge live tools/list for each enabled MCP plugin endpoint
#
# autoDream scheduled consolidation → memory/consolidated/autodream-*.md (staleness vs memory/.autodream_state.json)
# HSM_AUTODREAM=1
# HSM_AUTODREAM_INTERVAL_SECS=3600
# HSM_AUTODREAM_USE_HEARTBEAT_INTERVAL=1 # reuse HSM_HEARTBEAT_INTERVAL_SECS when set
#
# KAIROS-style wall-clock idle maintenance (personal_agent `start --daemon` only): runs autoDream + HEARTBEAT.md
# ticks without waiting for an inbound message. Pair with HSM_AUTODREAM=1 and HSM_HEARTBEAT_INTERVAL_SECS.
# HSM_KAIROS=1
# HSM_KAIROS_TICK_SECS=120

# Company console UI: `cargo run -p hyper-stigmergy --bin hsm_console` then `cd web/company-console && npm i && npm run dev`
# Email paste → draft: open console "Email draft" tab or POST JSON `{"text":"...","simple":true}` to `/api/console/email-draft` (Ollama required)
# Console profile flag is `--hsm-profile` / `-R` (not `-p` / `--profile` — `-p` is HTTP port). Or set `HSMII_PROFILE`.
# Company console: default is same-origin + Next rewrites to Rust (no var needed). Optional overrides:
# HSM_CONSOLE_URL=http://127.0.0.1:3847   # rewrite target (default if unset)
# NEXT_PUBLIC_API_BASE=http://127.0.0.1:3847  # only if you want the browser to call Rust directly (CORS)
# NEXT_PUBLIC_AGENT_CHAT_STREAM_URL=http://127.0.0.1:3050/api/agent-chat-reply/stream  # optional; if the UI document origin does not serve Next, set full URL to the stream route (Next-only; not on hsm_console)
# OPENROUTER_API_KEY=sk-or-...   # operator chat streaming (Next App Routes). Alias: HSM_OPENROUTER_API_KEY. Repo-root `.env` / `.env.local` are merged by `web/company-console/next.config.mjs` when not set under `web/company-console/`.
# HSM_DISABLE_WORKER_COMPANION_STREAM=1   # optional; disable parallel OpenRouter “sidecar” stream while worker dispatch runs (saves tokens; UI shows only runtime/tool events until worker finishes).
#
# Company console (Next): when adding a workspace from companies.sh, run the real CLI under this directory,
# then set company.hsmii_home to the installed pack folder (requires Node + network on the machine running `npm run dev`).
# mkdir -p ~/.hsm/company-packs && chmod 700 ~/.hsm/company-packs
# HSM_COMPANY_PACK_INSTALL_ROOT=/Users/you/.hsm/company-packs
# Optional: npm package name if not `companies.sh`
# HSM_COMPANIES_SH_NPX_PACKAGE=companies.sh
# Optional: comma-separated owner/repo allowlist (default: paperclipai/companies only)
# HSM_COMPANY_PACK_ALLOW_REPOS=paperclipai/companies,otherorg/otherrepo
# If the CLI leaves exactly one new folder in the install root, set to pick it when path detection fails:
# HSM_COMPANY_PACK_FALLBACK_NEWEST_DIR=1
# Optional: directory where pack idea submissions from the console marketplace are appended (JSONL). Unset = client opens upstream CONTRIBUTING instead.
# HSM_COMPANY_PACK_SUBMISSIONS_DIR=/var/lib/hsm/company-pack-ideas

# =============================================================================
# Browser Automation (optional)
# =============================================================================

BROWSERBASE_API_KEY=...
BROWSERBASE_PROJECT_ID=...
# Optional Browserbase session tuning (Hermes-grade interactive browsing)
# BROWSERBASE_SOLVE_CAPTCHAS=1          # maps to browserSettings.solveCaptchas when supported
# BROWSERBASE_VIEWPORT=1280x720
# BROWSERBASE_SESSION_JSON={"keepAlive":true}   # merged into POST /v1/sessions (merges browserSettings keys)

# xAI provider support (OpenAI-compatible transport)
# XAI_API_KEY=...
# XAI_BASE_URL=https://api.x.ai/v1
# HSM_XAI_PROMPT_CACHE=1
# XAI_PROMPT_CACHE_KEY=workspace-default
# HSM_XAI_THINKING_PREFILL=Let's reason step-by-step and continue from this thought:
#
# Native Gemini provider (OpenAI-compatible transport via Google AI Studio)
# GEMINI_API_KEY=...
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Optional hardened cron script actions (disabled by default)
# HSM_CRON_ALLOW_SCRIPT_ACTIONS=1
# HSM_CRON_SCRIPT_DIR=./config/cron-scripts
# HSM_CRON_ALLOWED_SCRIPTS=nightly_sync.sh,weekly_report.sh
#
# MCP plugin vulnerability scan policy (manifest gate)
# HSM_MCP_VULN_SCAN=1
# HSM_MCP_VULN_SCAN_MODE=enforce
# HSM_MCP_ALLOW_INSECURE=0
#
# MCP OAuth PKCE persisted state TTL (seconds)
# HSM_MCP_PKCE_STATE_TTL_SECS=900

# Matrix gateway scaffold (tier-1 expansion)
# MATRIX_HOMESERVER_URL=https://matrix.example.com
# MATRIX_ACCESS_TOKEN=...
# MATRIX_BOT_USER_ID=@hsm-bot:example.com

# Signal gateway scaffold (tier-1 media expansion)
# SIGNAL_API_BASE=https://signal-gateway.example.com
# SIGNAL_AUTH_TOKEN=...
# SIGNAL_BOT_NUMBER=+15551234567

# =============================================================================
# Cloudflare Web Search (optional)
# =============================================================================

CF_ACCOUNT_ID=...
CF_API_TOKEN=...

# =============================================================================
# Database (optional - defaults to SQLite)
# =============================================================================

DATABASE_URL=sqlite://./data/hsm.db

# Native LadybugDB graph (`lbug` crate). Requires building with `--features lbug` (C++/CMake).
# Path is the on-disk store prefix for `lbug::Database::new`, not the bincode world file.
# HSMII_LADYBUG_PATH=./data/hsm_native_lbug
# HSMII_LADYBUG_PRIMARY=1   # use Ladybug as primary world store (checkpoint + typed Cypher graph)
# HSMII_BINCODE_MIRROR=1    # when primary, also write world_state.ladybug.bincode
#
# SQLite file at DATABASE_URL is HsmSqliteStore (subsystem rows), not LadybugDB.
# Or for MySQL: DATABASE_URL=mysql://user:pass@localhost/hsm

# =============================================================================
# Observability
# =============================================================================

# Logging
RUST_LOG=info

# OpenTelemetry (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=hsm-ii

# Alert webhooks (comma-separated, optional)
ALERT_WEBHOOKS=https://hooks.slack.com/services/...,https://discord.com/api/webhooks/...

# Local smoke (build → synthetic eval artifacts → Trace2Skill → bootstrap + apply; optional LLM eval):
#   ./scripts/smoke_e2e.sh
#   SMOKE_RUN_LLM=1 SMOKE_CHAT=1 ./scripts/smoke_e2e.sh   # plus hsm-eval + one chat (needs LLM)
#   SMOKE_CHECK_LBUG=1 ./scripts/smoke_e2e.sh             # compile with Ladybug feature (needs CMake)
#
# =============================================================================
# HSM Configuration
# =============================================================================

HSM_MODE=production  # development, staging, production
HSM_DATA_DIR=./data
HSM_LOG_DIR=./logs

# Append one JSON line per personal-agent turn (skills path tool calls) for offline Trace2Skill merge.
# HSM_TRACE2SKILL_JSONL=./data/trajectories.jsonl
#
# Optional: one short LLM “lesson” per trajectory during `hsm_trace2skill merge` (needs OPENAI/ANTHROPIC/OLLAMA).
# HSM_TRACE2SKILL_LLM=1
#
# Pick up `hsm_trace2skill apply` without restarting personal_agent: reload skill bank from disk every N seconds.
# HSM_SKILL_BANK_RELOAD_SECS=120
#
# Markdown SKILL.md under <HSMII_HOME>/skills (+ optional extra dirs): rescan catalog every N seconds (0 = startup + HSM_INSTR_HOT_RELOAD only).
# HSM_SKILL_MD_RELOAD_SECS=120
#
# Extra SKILL.md trees, comma-separated (tilde expands with HOME). Same paths feed:
# - personal agent / skill_md_read (`skill_markdown`)
# - Company OS `POST …/import-paperclip-home` → `company_skills` for every workforce agent (pack `skills/` overrides on slug clash)
# Example: clone https://github.com/NousResearch/hermes-agent and point at its skills folder:
# HSM_SKILL_EXTERNAL_DIRS=/Users/you/src/hermes-agent/skills
#
# Agent Skills (agentskills.io): if set, skills with invalid name/description or name≠folder are skipped at catalog load (default: warn only).
# HSM_AGENT_SKILLS_STRICT=1
#
# ── Long-horizon harness (policy gate + tiered chat + tracing spans) ───────────────────────
# Isolated subagent: extra denied tools (comma-separated exact names).
# HSM_SUBAGENT_ISOLATED_DENY=bash,write_file,edit_file,git_push,git_commit,webhook_send,http_request
# Prefixes denied for isolated subagents (default mcp_).
# HSM_SUBAGENT_ISOLATED_DENY_PREFIXES=mcp_
#
# Tiered chat history for personal agent LLM calls (see harness::context_tier).
# HSM_CTX_CHAT_L0_MAX=4000
# HSM_CTX_CHAT_L1_MAX=24000
# HSM_CTX_CHAT_L2_MAX=120000
# HSM_CTX_MAX_TIER=l1
# HSM_CTX_CHAT_L1_TAIL_PAIRS=8
# HSM_CTX_CHAT_L0_LINE_CAP=240
#
# Tool executions emit tracing span `hsm.harness.tool`; LLM chat emits `hsm.harness.llm.chat`. Use RUST_LOG or JSON subscriber for collectors.
#
# Per-thread tool FS isolation: `read`/`write`/`edit`/`read_file`/`list_directory`/`grep`/`find`/… resolve under
# `<HSM_APPLIANCE_HOME>/workspaces/<sanitized_thread_id>/` (uploads/ + artifacts/ created automatically).
# HSM_THREAD_WORKSPACE=1
# Override data root for workspaces + `POST /api/agent-skills/install` target (`<home>/skills`). Default: ~/.hsmii
# HSM_APPLIANCE_HOME=/path/to/hsmii_home
#
# Bash tool: Docker is DEFAULT when an active thread workspace exists (Docker + HSM_THREAD_WORKSPACE=1).
# HSM_DOCKER_BASH=0                # turn off container wrap (host bash with minimal child env)
# HSM_UNSAFE_HOST_BASH=1           # explicit local-dev: same as disabling Docker wrap
# HSM_DOCKER_IMAGE=alpine:3.20
#
# Subprocess hardening (bash argv, grep, find, git, tar, …): env_clear + tiny allowlist — no inherited API keys.
# HSM_SUBPROCESS_INHERIT_FULL_ENV=1   # debug only; unsafe with untrusted agents
# HSM_SUBPROCESS_PATH=/usr/bin:/bin:/usr/sbin:/sbin
# HSM_SUBPROCESS_HOME=              # optional; else active workspace root or /tmp
# HSM_SUBPROCESS_TMPDIR=/tmp
#
# File tools: block reads under ~/.ssh, ~/.kube, ~/.env, … unless:
# HSM_ALLOW_SENSITIVE_PATHS=1
#
# Session-as-a-service (layer 10): GET /api/session/:thread_id/snapshot — workspace + optional Honcho hybrid_memory + world counts.
#
# Eval → Trace2Skill JSONL:  cargo run --bin hsm_trace2skill -- import-eval --artifacts runs/my_eval --out data/eval_trajectories.jsonl
# Merge then ingest:  cargo run --bin hsm_trace2skill -- merge --in data/traj.jsonl --out data/merged.json && cargo run --bin hsm_trace2skill -- apply --merged data/merged.json

# =============================================================================
# Eval harness (keyword + rubric, grounding, tool checks; wall-clock / HTTP counts in metrics)
# See docs/EVAL_AND_META_HARNESS.md — hsm-eval vs hsm_meta_harness vs hsm_outer_loop, artifacts, smoke.
# =============================================================================

# Minimum keyword overlap for deterministic pass (default 0.45).
# HSM_EVAL_KEYWORD_PASS=0.45
# Minimum memory/context overlap for grounding pass on recall turns (default 0.12).
# HSM_EVAL_GROUNDING_PASS=0.12
# Set to 1 to allow an extra LLM JSON judge on turns that fail the deterministic rubric ({"pass","reason"}).
# HSM_EVAL_LLM_JUDGE=1

# Meta-harness: path to JSON array of HsmRunnerConfig or {"candidates":[...]} (overridable by --config).
# HSM_META_HARNESS_CONFIG=./config/hsm_harness.example.json

# Optional parent run id for manifest linkage (outer-loop / nested evals).
# HSM_PARENT_RUN_ID=run_abc123

# Append-only index of eval/meta-harness runs (default path: runs/runs_index.jsonl next to run dirs).
# Inspect:  cargo run --bin hsm_outer_loop -- list-runs --index runs/runs_index.jsonl
#
# SQLite mirror for queries (ingest JSONL after each meta-harness / eval that appends the index):
#   cargo run --bin hsm_outer_loop -- index-db --jsonl runs/runs_index.jsonl --db runs/runs.sqlite
#   cargo run --bin hsm_outer_loop -- query-db --db runs/runs.sqlite --harness hsm_meta_harness
# Proposer context JSON for a coding agent (harness file list + recent / best runs):
#   cargo run --bin hsm_outer_loop -- propose --workspace . --db runs/runs.sqlite --sync-jsonl runs/runs_index.jsonl
#
# Auto-sync each appended index line into SQLite (same path as --db above):
# HSM_RUNS_SQLITE=./runs/runs.sqlite
#
# Full-text search over ingested rows (FTS5): phrase / AND / OR — see SQLite docs.
#   cargo run --bin hsm_outer_loop -- query-db --db runs/runs.sqlite --fts 'hsm_meta AND objective'
# After upgrading schema, re-index FTS:  index-db ... --rebuild-fts

# =============================================================================
# Gaps 1,3–12 helpers (tools, harness, session, cron)
# =============================================================================

# JSONL tool-step checkpoints (gap 1)
# HSM_HARNESS_TOOL_CHECKPOINT_DIR=/var/lib/hsm/tool_ckpt

# Tool retries on transient errors (gap 3)
# HSM_TOOL_RETRY_MAX=2
# HSM_TOOL_RETRY_MS=400

# Prompt section order + caps (gap 4) — keys: living,memory,route,business,prefetch,belief,skill,autocontext,md_skills,tail
# HSM_PROMPT_SECTION_ORDER=living,memory,tail
# HSM_PROMPT_CAP_memory=8000

# Deny specific tools globally (gap 7)
# HSM_TOOL_DENY_NETWORK=web_search,http_request

# Middle chat collapse for L1/L2 tiers (gap 8)
# HSM_CTX_COLLAPSE_MIDDLE=1

# Human approval for listed tools (gap 9) — comma-separated tool names
# HSM_TOOL_APPROVAL_LIST=bash,write_file

# Session JSONL under <appliance_home>/sessions/<thread_id>/ (gap 10); optional XOR obfuscation
# HSM_SESSION_SECRET=change-me

# File cron for personal_agent daemon (gap 11)
# HSM_CRON_CONFIG=./config/hsm_cron.json

# Correlation id for harness / tracing (gap 12)
# HSM_HARNESS_NO_AUTO_CORRELATION=1
# HSM_HARNESS_CORRELATION_ID=run-abc

# Bash argv-only mode (gap 6)
# HSM_BASH_ARGV_ONLY=1
# HSM_BASH_ARGV_ALLOWLIST=ls,git,cat

# =============================================================================
# Product telemetry (optional — off by default)
# =============================================================================
#
# Mirrors typical AI-product policy buckets: technical usage (always when on),
# optional hashed workspace (account context), optional conversation content,
# plus hooks for safety/support events from your code.
#
# HSM_TELEMETRY=1
# HSM_TELEMETRY_ENDPOINT=https://your-collector.example/v1/ingest
# HSM_TELEMETRY_KEY=                                    # optional Bearer token
# HSM_TELEMETRY_INSTALL_ID=                             # optional stable anon id
# HSM_TELEMETRY_INCLUDE_CONVERSATION=0                  # 1 = include raw user/assistant text in conversation.* events
# HSM_TELEMETRY_INCLUDE_ACCOUNT_METADATA=0              # 1 = attach SHA-256 prefix of HSM_TELEMETRY_WORKSPACE_LABEL
# HSM_TELEMETRY_WORKSPACE_LABEL=my-workspace-or-org-slug
#
# Call sites: `hyper_stigmergy::telemetry::init_from_env()` after loading `.env`
# (see hsm_api, hsm_console, personal_agent). Use `TelemetryClient::record_conversation_turn`
# etc. from integrations when you add conversation-level events.

# =============================================================================
# Operator policy + context manifest (optional)
# =============================================================================
#
# YAML policy: context tier labels per prompt section + tools.deny for HarnessPolicyGate.
# Example: cp templates/hsmii/policy.example.yaml ~/.hsmii/policy.yaml
# HSM_POLICY_FILE=/path/to/policy.yaml
#
# Log full JSON context manifest at DEBUG (large): HSM_LOG_CONTEXT_MANIFEST=1
# RUST_LOG=hsm.context_manifest=info
# Applies to personal-agent prompt assembly and Company OS GET /api/company/tasks/{id}/llm-context (response includes `context_manifest` JSON).

# =============================================================================
# Grafana (optional)
# =============================================================================

GRAFANA_PASSWORD=admin
