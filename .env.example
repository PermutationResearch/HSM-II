# HSM-II Environment Configuration
# Copy to .env and fill in your values

# =============================================================================
# LLM Configuration (at least one required)
# =============================================================================

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1  # Optional

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1  # Optional

# Ollama (local inference, no API key needed)
OLLAMA_URL=http://localhost:11434

# Cloud model (qwencoder:480b-cloud) - OpenRouter free tier
OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_API_BASE=https://openrouter.ai/api/v1  # optional
# CLOUD_MODEL_ID=qwen/qwen3-coder:free              # optional

# Default model to use
DEFAULT_LLM_MODEL=gpt-4o-mini

# =============================================================================
# Browser Automation (optional)
# =============================================================================

BROWSERBASE_API_KEY=...
BROWSERBASE_PROJECT_ID=...

# =============================================================================
# Cloudflare Web Search (optional)
# =============================================================================

CF_ACCOUNT_ID=...
CF_API_TOKEN=...

# =============================================================================
# Database (optional - defaults to SQLite)
# =============================================================================

DATABASE_URL=sqlite://./data/hsm.db

# Native LadybugDB graph (`lbug` crate). Requires building with `--features lbug` (C++/CMake).
# Path is the on-disk store prefix for `lbug::Database::new`, not the bincode world file.
# HSMII_LADYBUG_PATH=./data/hsm_native_lbug
# HSMII_LADYBUG_PRIMARY=1   # use Ladybug as primary world store (checkpoint + typed Cypher graph)
# HSMII_BINCODE_MIRROR=1    # when primary, also write world_state.ladybug.bincode
#
# SQLite file at DATABASE_URL is HsmSqliteStore (subsystem rows), not LadybugDB.
# Or for MySQL: DATABASE_URL=mysql://user:pass@localhost/hsm

# =============================================================================
# Observability
# =============================================================================

# Logging
RUST_LOG=info

# OpenTelemetry (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=hsm-ii

# Alert webhooks (comma-separated, optional)
ALERT_WEBHOOKS=https://hooks.slack.com/services/...,https://discord.com/api/webhooks/...

# =============================================================================
# HSM Configuration
# =============================================================================

HSM_MODE=production  # development, staging, production
HSM_DATA_DIR=./data
HSM_LOG_DIR=./logs

# Append one JSON line per personal-agent turn (skills path tool calls) for offline Trace2Skill merge.
# HSM_TRACE2SKILL_JSONL=./data/trajectories.jsonl
#
# Optional: one short LLM “lesson” per trajectory during `hsm_trace2skill merge` (needs OPENAI/ANTHROPIC/OLLAMA).
# HSM_TRACE2SKILL_LLM=1
#
# Pick up `hsm_trace2skill apply` without restarting personal_agent: reload skill bank from disk every N seconds.
# HSM_SKILL_BANK_RELOAD_SECS=120
#
# Eval → Trace2Skill JSONL:  cargo run --bin hsm_trace2skill -- import-eval --artifacts runs/my_eval --out data/eval_trajectories.jsonl
# Merge then ingest:  cargo run --bin hsm_trace2skill -- merge --in data/traj.jsonl --out data/merged.json && cargo run --bin hsm_trace2skill -- apply --merged data/merged.json

# =============================================================================
# Eval harness (keyword + rubric, grounding, tool checks; wall-clock / HTTP counts in metrics)
# =============================================================================

# Minimum keyword overlap for deterministic pass (default 0.45).
# HSM_EVAL_KEYWORD_PASS=0.45
# Minimum memory/context overlap for grounding pass on recall turns (default 0.12).
# HSM_EVAL_GROUNDING_PASS=0.12
# Set to 1 to allow an extra LLM JSON judge on turns that fail the deterministic rubric ({"pass","reason"}).
# HSM_EVAL_LLM_JUDGE=1

# Meta-harness: path to JSON array of HsmRunnerConfig or {"candidates":[...]} (overridable by --config).
# HSM_META_HARNESS_CONFIG=./config/hsm_harness.example.json

# Optional parent run id for manifest linkage (outer-loop / nested evals).
# HSM_PARENT_RUN_ID=run_abc123

# Append-only index of eval/meta-harness runs (default path: runs/runs_index.jsonl next to run dirs).
# Inspect:  cargo run --bin hsm_outer_loop -- list-runs --index runs/runs_index.jsonl
#
# SQLite mirror for queries (ingest JSONL after each meta-harness / eval that appends the index):
#   cargo run --bin hsm_outer_loop -- index-db --jsonl runs/runs_index.jsonl --db runs/runs.sqlite
#   cargo run --bin hsm_outer_loop -- query-db --db runs/runs.sqlite --harness hsm_meta_harness
# Proposer context JSON for a coding agent (harness file list + recent / best runs):
#   cargo run --bin hsm_outer_loop -- propose --workspace . --db runs/runs.sqlite --sync-jsonl runs/runs_index.jsonl
#
# Auto-sync each appended index line into SQLite (same path as --db above):
# HSM_RUNS_SQLITE=./runs/runs.sqlite
#
# Full-text search over ingested rows (FTS5): phrase / AND / OR — see SQLite docs.
#   cargo run --bin hsm_outer_loop -- query-db --db runs/runs.sqlite --fts 'hsm_meta AND objective'
# After upgrading schema, re-index FTS:  index-db ... --rebuild-fts

# =============================================================================
# Grafana (optional)
# =============================================================================

GRAFANA_PASSWORD=admin
