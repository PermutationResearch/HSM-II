{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hsm-ii.local/schemas/a2a/delegate_task.params.schema.json",
  "title": "delegate_task params",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "trace_id",
    "task_id",
    "delegation_id",
    "from_agent",
    "to_agent",
    "objective",
    "acceptance_criteria",
    "constraints",
    "inputs"
  ],
  "properties": {
    "trace_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "delegation_id": { "type": "string", "minLength": 1 },
    "from_agent": { "type": "string", "minLength": 1 },
    "to_agent": { "type": "string", "minLength": 1 },
    "objective": { "type": "string", "minLength": 1 },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deadline_unix", "max_tokens_budget", "allowed_tools"],
      "properties": {
        "deadline_unix": { "type": "integer", "minimum": 0 },
        "max_tokens_budget": { "type": "integer", "minimum": 1 },
        "allowed_tools": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo_ref"],
      "properties": {
        "repo_ref": { "type": "string", "minLength": 1 },
        "files": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "context_artifact_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
