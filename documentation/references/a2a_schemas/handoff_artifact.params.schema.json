{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hsm-ii.local/schemas/a2a/handoff_artifact.params.schema.json",
  "title": "handoff_artifact params",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "trace_id",
    "task_id",
    "delegation_id",
    "from_agent",
    "to_agent",
    "artifact"
  ],
  "properties": {
    "trace_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "delegation_id": { "type": "string", "minLength": 1 },
    "from_agent": { "type": "string", "minLength": 1 },
    "to_agent": { "type": "string", "minLength": 1 },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "type", "uri", "checksum_sha256", "metadata"],
      "properties": {
        "artifact_id": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": ["code_patch", "test_report", "log_bundle", "design_doc", "other"]
        },
        "uri": { "type": "string", "minLength": 1 },
        "checksum_sha256": { "type": "string", "minLength": 8 },
        "metadata": { "type": "object" }
      }
    }
  }
}
