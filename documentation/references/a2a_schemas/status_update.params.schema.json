{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hsm-ii.local/schemas/a2a/status_update.params.schema.json",
  "title": "status_update params",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "trace_id",
    "task_id",
    "delegation_id",
    "from_agent",
    "state",
    "timestamp_unix"
  ],
  "properties": {
    "trace_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "delegation_id": { "type": "string", "minLength": 1 },
    "from_agent": { "type": "string", "minLength": 1 },
    "state": {
      "type": "string",
      "enum": ["queued", "in_progress", "blocked", "completed", "failed"]
    },
    "percent": { "type": "number", "minimum": 0, "maximum": 100 },
    "message": { "type": "string" },
    "blocked": { "type": "boolean" },
    "timestamp_unix": { "type": "integer", "minimum": 0 }
  }
}
