{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hsm-ii.local/schemas/a2a/discover_capabilities.params.schema.json",
  "title": "discover_capabilities params",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "trace_id",
    "task_id",
    "from_agent",
    "query"
  ],
  "properties": {
    "trace_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "from_agent": { "type": "string", "minLength": 1 },
    "query": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capabilities_any"],
      "properties": {
        "capabilities_any": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "domain": { "type": "string" },
        "max_candidates": { "type": "integer", "minimum": 1, "maximum": 50 }
      }
    }
  }
}
